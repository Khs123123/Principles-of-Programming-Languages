#lang racket
(require rackunit)
(require rackunit/text-ui)

(define tests
    (test-suite "Assignment 1 - Part 4"
    
        (test-suite "last-item"
            (check-equal? (last-item '(1 2 3)) 3)
            (check-equal? (last-item '(a b c)) 'c)
            (check-equal? (last-item '(42)) 42)
            (check-equal? (last-item '("hello" "world")) "world")
        )

        (test-suite "remove-last-item"
            (check-equal? (remove-last-item '(1 2 3)) '(1 2))
            (check-equal? (remove-last-item '(a b c d)) '(a b c))
            (check-equal? (remove-last-item '(42)) '())
            (check-equal? (remove-last-item '("hello" "world")) '("hello"))
        )

        (test-suite "rotate-nth"
            (check-equal? (rotate-nth '(1 2 3) 1) '(3 1 2))
            (check-equal? (rotate-nth '(a b c d) 2) '(c d a b))
            (check-equal? (rotate-nth '(1 2 3 4 5) 3) '(3 4 5 1 2))
            (check-equal? (rotate-nth '(hello world) 1) '(world hello))
            (check-equal? (rotate-nth '(x y z) 0) '(x y z))
        )
    )
)

(run-tests tests)

;; --- TEST CASES ---
(newline)
(display "--- Testing last-item ---") (newline)
(display "(last-item '(1 2 3)) => ") (display (last-item '(1 2 3))) (newline)
(display "(last-item '(a b c)) => ") (display (last-item '(a b c))) (newline)
(display "(last-item '(42)) => ") (display (last-item '(42))) (newline)
(display "(last-item '(\"hello\" \"world\")) => ") (display (last-item '("hello" "world"))) (newline)

(newline)
(display "--- Testing remove-last-item ---") (newline)
(display "(remove-last-item '(1 2 3)) => ") (display (remove-last-item '(1 2 3))) (newline)
(display "(remove-last-item '(a b c d)) => ") (display (remove-last-item '(a b c d))) (newline)
(display "(remove-last-item '(42)) => ") (display (remove-last-item '(42))) (newline)
(display "(remove-last-item '(\"hello\" \"world\")) => ") (display (remove-last-item '("hello" "world"))) (newline)

(newline)
(display "--- Testing rotate-nth ---") (newline)
(display "(rotate-nth '(1 2 3) 1) => ") (display (rotate-nth '(1 2 3) 1)) (newline)
(display "(rotate-nth '(a b c d) 2) => ") (display (rotate-nth '(a b c d) 2)) (newline)
(display "(rotate-nth '(1 2 3 4 5) 3) => ") (display (rotate-nth '(1 2 3 4 5) 3)) (newline)
(display "(rotate-nth '(hello world) 1) => ") (display (rotate-nth '(hello world) 1)) (newline)
(display "(rotate-nth '(x y z) 0) => ") (display (rotate-nth '(x y z) 0)) (newline)

(newline)
(display "--- Testing deep-reverse ---") (newline)
(display "Flat list: (deep-reverse '(1 2 3)) => ") (display (deep-reverse '(1 2 3))) (newline)
(display "Assignment Example: (deep-reverse '(1 (2 3) (4 5))) => ") (display (deep-reverse '(1 (2 3) (4 5)))) (newline)
(display "Empty list: (deep-reverse '()) => ") (display (deep-reverse '())) (newline)
(display "Deeply nested: (deep-reverse '((1 2) (3 (4 5)))) => ") (display (deep-reverse '((1 2) (3 (4 5))))) (newline)
(newline)
